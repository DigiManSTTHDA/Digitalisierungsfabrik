{
  "name": "digitalisierungsfabrik-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "generate-api": "openapi-typescript http://localhost:8000/openapi.json -o src/generated/api.d.ts",
    "generate-api:file": "openapi-typescript ../api-contract/openapi.json -o src/generated/api.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
