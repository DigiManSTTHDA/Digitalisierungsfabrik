# LLM Provider: "anthropic", "openai" or "ollama"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6
LLM_API_KEY=sk-ant-...

# OpenAI example:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# SQLite database file path
DATABASE_PATH=./data/digitalisierungsfabrik.db

# Dialog history window sizes
DIALOG_HISTORY_N=3
DIALOG_HISTORY_MODERATOR_M=10

# Token limits
TOKEN_WARN_THRESHOLD=80000
TOKEN_HARD_LIMIT=100000

# Automation threshold (SDD 8.1.2)
AUTOMATION_WARN_THRESHOLD=1

# Logging
LOG_LEVEL=INFO
LLM_LOG_ENABLED=true
